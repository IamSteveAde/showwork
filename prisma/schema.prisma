// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// CREATOR — the Spotlite product's customer
// (auth itself is handled by Supabase Auth; this table
// just mirrors the creator's id + a few product-specific fields)
// ─────────────────────────────────────────────
enum SubscriptionTier {
  FREE
  STARTER
  GROWTH
  UNLIMITED
}

model Creator {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  // Which paid tier they're on, and whether that tier is currently in
  // good standing. If subscriptionActive is false (lapsed, cancelled,
  // failed renewal), the creator is treated as FREE for cap purposes
  // regardless of what subscriptionTier still says — that field is kept
  // as a historical/display record, not the source of truth for access.
  subscriptionTier         SubscriptionTier @default(FREE)
  subscriptionActive       Boolean          @default(false)
  paystackCustomerCode     String?
  paystackSubscriptionCode String?
  paystackEmailToken       String?
  subscriptionRenewsAt     DateTime?

  // The start of the current billing cycle for a paid tier — updated to
  // "now" every time a subscription is created or renews, so project
  // counts can be measured against it. Free tier doesn't use this; it
  // uses a rolling 30-day window computed at read time instead, since
  // there's no billing event to anchor a free cycle to.
  currentCycleStart DateTime @default(now())

  // Admin controls. isComped grants full Unlimited-tier access without
  // any real Paystack subscription — checked ahead of subscriptionActive
  // everywhere access is gated. discountPercent (0-100) is applied the
  // next time this creator starts or switches a subscription — it
  // doesn't retroactively change an already-active one.
  isComped        Boolean @default(false)
  discountPercent Int     @default(0)

  projects       Project[]
  paymentRecords      PaymentRecord[]
  passwordResetTokens PasswordResetToken[]
}

// ─────────────────────────────────────────────
// PROJECT — one client delivery (e.g. "Soundhous 2026")
// ─────────────────────────────────────────────
model Project {
  id        String  @id @default(uuid())
  slug      String  @unique // used in the URL: yourproduct.com/{slug}
  clientName String

  // access control
  passwordHash String
  // Plain-text copy of the same code, saved purely so the creator can
  // see and re-share it later. This one code only gates a client's
  // view of their own delivery — not an account or anything sensitive —
  // so keeping a readable copy is a reasonable tradeoff here. Older
  // projects created before this field existed will have this as null.
  accessCode   String?

  // Option A payment: one-time ₦5,000 per project
  paid           Boolean   @default(false)
  paidAt         DateTime?
  paystackRef    String?   @unique // Paystack transaction reference

  // whether the free-tier Spotlite badge shows on this project
  // automatically false once `paid` is true
  badgeVisible Boolean @default(true)

  // whether viewers must submit an email before the password screen
  // defaults on for free tier, creator can toggle off once paid
  captureViewerEmail Boolean @default(true)

  // branding (all optional — falls back to default Spotlite styling)
  logoUrl      String?
  primaryColor String? // e.g. "#C9A84C"
  bgColor      String? // e.g. "#080808"

  // The hero banner: creator picks which uploaded file leads the page,
  // and writes a line of copy tailored to that specific client. Plain
  // string id (not a formal relation) — resolved against project.media
  // in application code, so a deleted file just falls back gracefully.
  heroMediaId String?
  heroTagline String?

  // Real page-view counter — increments on every load of the public
  // delivery page, regardless of whether email capture is even turned
  // on. Separate from ViewerEmail, which only records people who
  // actually submitted their email.
  viewCount Int @default(0)

  // Counts every file replacement (revision uploads) across this
  // project's lifetime. Capped in application code — without this, a
  // single ₦5,000 payment could otherwise be stretched into an
  // unlimited free pipeline by repeatedly swapping in unrelated content.
  replaceCount Int @default(0)

  // Counts how many times a creator has used "Add more files" after the
  // project was first created. Capped in application code — without this,
  // one payment could keep growing forever into an unrelated ongoing
  // delivery, same reasoning as the replace-file cap.
  additionalUploadCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String

  media        Media[]
  viewerEmails ViewerEmail[]
}

// ─────────────────────────────────────────────
// MEDIA — one photo or video within a project
// ─────────────────────────────────────────────
enum MediaType {
  PHOTO
  VIDEO
}

enum ApprovalStatus {
  PENDING
  APPROVED
  NEEDS_REVISION
}

model Media {
  id           String    @id @default(uuid())
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  type         MediaType
  fileKey      String    // R2 object key, e.g. "projects/{projectId}/video/invisible.mp4"
  caption      String?
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())

  // Client review — set by whoever's viewing the delivery page, not the
  // creator. NEEDS_REVISION carries an optional note explaining why.
  approvalStatus ApprovalStatus @default(PENDING)
  approvalNote   String?
  reviewedAt     DateTime?
  // The email of whoever left the most recent review on this file —
  // captured from the mandatory viewer email gate. Used to notify them
  // specifically once a flagged file gets replaced.
  reviewerEmail  String?
}

// ─────────────────────────────────────────────
// VIEWER EMAIL — captured from the client's client
// (the lead-gen mechanism)
// ─────────────────────────────────────────────
model ViewerEmail {
  id        String   @id @default(uuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  email     String
  viewedAt  DateTime @default(now())

  @@index([projectId])
}

// ─────────────────────────────────────────────
// PENDING SIGNUP — a signup that hasn't verified its email yet.
// The real Creator row only gets created once the OTP is confirmed;
// until then, everything (including the already-hashed password)
// sits here so nothing is stored twice.
// ─────────────────────────────────────────────
model PendingSignup {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String
  otpCode       String
  otpExpiresAt  DateTime
  createdAt     DateTime @default(now())
}

// ─────────────────────────────────────────────
// PAYMENT RECORD — a permanent log of every real charge, populated by
// the webhook. This is the actual source of truth for revenue reporting;
// subscriptionActive/subscriptionTier only reflect *current* state and
// can't answer "how much did we make in March," so this table exists
// specifically to make that answerable.
// ─────────────────────────────────────────────
enum PaymentType {
  PROJECT_ONE_TIME
  SUBSCRIPTION_INITIAL
  SUBSCRIPTION_RENEWAL
}

model PaymentRecord {
  id                String      @id @default(uuid())
  creator           Creator     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId         String
  amountNgn         Int
  type              PaymentType
  tier              SubscriptionTier?
  paystackReference String?
  createdAt         DateTime    @default(now())

  @@index([creatorId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// PLATFORM SETTINGS — a single-row config table. Currently just holds
// the platform-wide discount percentage an admin can set, applied to
// every new subscription started while it's active.
// ─────────────────────────────────────────────
model PlatformSettings {
  id                    String @id @default("singleton")
  globalDiscountPercent Int    @default(0)
}

// ─────────────────────────────────────────────
// PASSWORD RESET TOKEN — short-lived, single-use. The token stored here
// is a hash, never the plain value — same principle as passwords
// themselves. The plain token only ever exists in the email link itself.
// ─────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(uuid())
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([creatorId])
}
