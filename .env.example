# Postgres connection string (e.g. from Supabase's connection pooling URL)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Random long string used to sign session JWTs — generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-string"

# Your deployed app URL (no trailing slash)
NEXT_PUBLIC_APP_URL="https://yourproduct.com"

# Cloudflare R2
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# Paystack
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxx"
